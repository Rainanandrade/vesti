{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": { "buildType": "apk" },
      "ios": { "simulator": true }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": { "resourceClass": "m-medium" },
      "android": { "resourceClass": "medium" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "PREENCHER_SEU_EMAIL_APPLE_ID",
        "ascAppId": "PREENCHER_DEPOIS_DE_CRIAR_APP_NO_APP_STORE_CONNECT",
        "appleTeamId": "PREENCHER_DEPOIS_DE_CRIAR_CONTA_DEV"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-key.json",
        "track": "internal"
      }
    }
  }
}
